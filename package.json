{
  "name": "doctors-portal",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,magenta \"npm run dev -w doctors-portal-frontend\" \"npm run dev -w doctors-portal-backend\"",
    "dev:frontend": "npm run dev -w doctors-portal-frontend",
    "dev:backend": "npm run dev -w doctors-portal-backend",
    "build": "npm run build -w doctors-portal-frontend",
    "lint": "npm run lint -w doctors-portal-frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
